# ============================================================================
# CityStressTest Environment Variables
# ============================================================================
#
# ⚠️ IMPORTANT: VITE_GEMINI_API_KEY is REQUIRED
# This application fetches ALL data live from Google Gemini API.
# There is NO hardcoded data for any location.
# Every request must go through Gemini API with Google Search grounding.
#
# For Vercel Deployment:
# 1. Go to your Vercel project settings
# 2. Navigate to Environment Variables
# 3. Add VITE_GEMINI_API_KEY with your actual key value
# 4. Redeploy your project
#
# For Local Development:
# 1. Copy this file to .env.local
# 2. Add your VITE_GEMINI_API_KEY value
# 3. Run: npm run dev
# ============================================================================

# ⚠️ REQUIRED: Google Gemini API Key
# Get your API key from: https://aistudio.google.com/app/apikey
#
# This is MANDATORY. The app will NOT work without a valid API key.
# Every location analysis requires a Gemini API call with Google Search grounding.
#
# Example: sk-proj-abc123xyz789...
VITE_GEMINI_API_KEY=your_actual_api_key_here

# Optional: Gemini Model Name
# Default: gemini-2.0-flash (recommended - latest and most capable)
# Other options:
#   - gemini-2.0-flash-exp (experimental, higher capabilities)
#   - gemini-1.5-pro (previous generation)
#   - gemini-1.5-flash (smaller, faster, lower cost)
#
# IMPORTANT: Model must support:
#   - Google Search grounding (@google_search tool)
#   - JSON output mode (responseMimeType: "application/json")
#
# For Vercel: Set this in project Environment Variables
VITE_GEMINI_MODEL=gemini-2.0-flash

# Optional: Application URL
# Used for self-referential links and OAuth callbacks
# In Vercel, this is automatically available as VERCEL_URL
# For local dev: http://localhost:3000
# For production: https://your-domain.com
APP_URL=http://localhost:3000

# Optional: Disable Hot Module Replacement (HMR)
# Set to "true" in production or AI Studio deployments to reduce CPU usage
# Default: false (HMR enabled for better development experience)
DISABLE_HMR=false
